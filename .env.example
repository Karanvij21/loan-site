# ───────────────────────────────────────────────
# Site
# ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME="Fast Loan Advance"
NEXT_PUBLIC_BRAND_PHONE="+1-800-000-0000"
NEXT_PUBLIC_BRAND_EMAIL="support@yourdomain.com"

# ───────────────────────────────────────────────
# Supabase — get from https://app.supabase.com
# ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ───────────────────────────────────────────────
# LendingTree (apply at lendingtree.com/about/partner-with-us)
# Fill in once approved. Endpoint URL is provided in onboarding docs.
# ───────────────────────────────────────────────
LENDINGTREE_API_URL=
LENDINGTREE_PARTNER_ID=
LENDINGTREE_API_KEY=
LENDINGTREE_SUB_ID=

# ───────────────────────────────────────────────
# Plaid — https://dashboard.plaid.com
# ───────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ───────────────────────────────────────────────
# SendGrid (email) — https://app.sendgrid.com
# ───────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ───────────────────────────────────────────────
# Analytics
# ───────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=

# ───────────────────────────────────────────────
# Trustpilot (optional)
# ───────────────────────────────────────────────
NEXT_PUBLIC_TRUSTPILOT_BUSINESS_ID=
