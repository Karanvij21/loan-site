# ───────────────────────────────────────────────
# Site
# ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://getadvanceloan.com
NEXT_PUBLIC_SITE_NAME="Get Advance Loan"
# Legal operating entity — must match your Google Ads MCC / advertiser
# verification name to avoid identity-mismatch disapprovals.
NEXT_PUBLIC_LEGAL_ENTITY="Stellar Commerce Solutions LLC"
NEXT_PUBLIC_BRAND_PHONE="+1-800-000-0000"
NEXT_PUBLIC_BRAND_EMAIL="support@getadvanceloan.com"
# CAN-SPAM requires a valid physical postal address in every commercial email.
# Set this before running marketing campaigns. A PO box is fine.
NEXT_PUBLIC_BRAND_ADDRESS="Your Company Name, 1234 Address, City, ST 12345"

# ───────────────────────────────────────────────
# Supabase — get from https://app.supabase.com
# ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ───────────────────────────────────────────────
# LendingTree (apply at lendingtree.com/about/partner-with-us)
# Fill in once approved. Endpoint URL is provided in onboarding docs.
# ───────────────────────────────────────────────
LENDINGTREE_API_URL=
LENDINGTREE_PARTNER_ID=
LENDINGTREE_API_KEY=
LENDINGTREE_SUB_ID=

# ───────────────────────────────────────────────
# Plaid — https://dashboard.plaid.com
# ───────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ───────────────────────────────────────────────
# SendGrid (email) — https://app.sendgrid.com
# ───────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@getadvanceloan.com

# ───────────────────────────────────────────────
# Analytics
# ───────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=

# ───────────────────────────────────────────────
# Trustpilot (optional)
# ───────────────────────────────────────────────
NEXT_PUBLIC_TRUSTPILOT_BUSINESS_ID=

# ───────────────────────────────────────────────
# OneSignal Web Push — https://onesignal.com
# Sign up, create a Web Push app for getadvanceloan.com, paste App ID below.
# ───────────────────────────────────────────────
NEXT_PUBLIC_ONESIGNAL_APP_ID=
# Server-only REST API key (sensitive). Find at OneSignal dashboard:
# Settings -> Keys & IDs -> "Rest API Key". Used to fire server-side pushes
# from /api/lead via the OneSignal REST API.
ONESIGNAL_REST_API_KEY=

# ───────────────────────────────────────────────
# Admin dashboard
# Set these to gate /admin/* behind HTTP Basic Auth.
# When either is unset, /admin returns 503 (safe-fail).
# ───────────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
